defun run() {
    var status = 'start'

    var result = try {
        throw 'boom'
    } catch (err) {
        status = 'caught'
        err
    } finally {
        status = 'caught!'
    }

    var builder = new system.text.stringBuilder()
    builder.Append(result)
    builder.Append(' / ')
    builder.Append(status)
    builder.ToString()
}
